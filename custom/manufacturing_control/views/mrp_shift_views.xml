<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tdmx_shift_list_view" model="ir.ui.view">
        <field name="name">tdmx.shift.list</field>
        <field name="model">tdmx.shift</field>
        <field name="arch" type="xml">
            <list string="Turnos">
                <field name="number" />
                <field name="name" />
                <field name="start_time" widget="float_time" />
                <field name="end_time" widget="float_time" />
            </list>
        </field>
    </record>

    <record id="tdmx_shift_form_view" model="ir.ui.view">
        <field name="name">tdmx.shift.form</field>
        <field name="model">tdmx.shift</field>
        <field name="arch" type="xml">
            <form string="Turno">
                <sheet>
                    <group>
                        <group>
                            <field name="number" />
                            <field name="name" />
                        </group>
                        <group>
                            <field name="start_time" widget="float_time" />
                            <field name="end_time" widget="float_time" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_my_mrp_shift" model="ir.actions.act_window">
        <field name="name">Turnos</field>
        <field name="res_model">tdmx.shift</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>