<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_workorder_form_view_inherit_kiosk" model="ir.ui.view">
        <field name="name">mrp.workorder.form.kiosk</field>
        <field name="model">mrp.workorder</field>
        <field name="inherit_id" ref="mrp.mrp_production_workorder_form_view_inherit" />
        <field name="arch" type="xml">
            <!-- Notebook page: Declaraciones Kiosco -->
            <xpath expr="//notebook" position="inside">
                <page string="Declaraciones Kiosco" name="kiosk_production">
                    <field name="shift_declaration_ids" readonly="1">
                        <list decoration-success="state=='done'" decoration-danger="state=='error'">
                            <field name="date_declared" />
                            <field name="employee_id" />
                            <field name="qty_declared" sum="Total" />
                            <field name="state" widget="badge" decoration-success="state == 'done'"
                                decoration-danger="state == 'error'"
                                decoration-info="state == 'draft'" />
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>