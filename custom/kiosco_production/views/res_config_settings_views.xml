<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_inherit" model="ir.ui.view">
        <field name="name">res.config.settings.form.manufacturing_control</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="mrp.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//app[@name='mrp']" position="inside">
                <block title="Kiosco de Producción"
                    help="Configuración de umbrales para el kiosco de producción.">
                    <setting string="Alerta de Sobreproducción"
                        help="Porcentaje de la meta a partir del cual se muestra una advertencia amarilla al operario.">
                        <div class="content-group">
                            <div class="row mt8">
                                <label class="col-lg-3 o_light_label"
                                    for="manufacturing_overproduction_warning" />
                                <field name="manufacturing_overproduction_warning"
                                    class="col-lg-2" />
                                <span>%</span>
                            </div>
                        </div>
                    </setting>
                    <setting string="Bloqueo de Sobreproducción"
                        help="Porcentaje de la meta a partir del cual se bloquea el registro de producción.">
                        <div class="content-group">
                            <div class="row mt8">
                                <label class="col-lg-3 o_light_label"
                                    for="manufacturing_overproduction_block" />
                                <field name="manufacturing_overproduction_block"
                                    class="col-lg-2" />
                                <span>%</span>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

</odoo>