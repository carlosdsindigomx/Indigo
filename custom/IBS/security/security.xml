<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="module_category_ibs_cotizador" model="ir.module.category">
            <field name="name">Cotizador IBS</field>
            <field name="sequence">15</field>
        </record>

        <record id="privilege_cotizar_producto" model="res.groups.privilege">
            <field name="name">Cotizar producto</field>
            <field name="category_id" ref="module_category_ibs_cotizador"/>
            <field name="sequence">10</field>
        </record>
        <record id="group_cotizar_producto" model="res.groups">
            <field name="name">Ver pestañas comerciales</field>
            <field name="privilege_id" ref="privilege_cotizar_producto"/>
            <field name="comment">Habilita: Medidas, Estructura, Acabados, Envío, Rangos y Otros.</field>
        </record>

        <record id="privilege_costos" model="res.groups.privilege">
            <field name="name">Costos</field>
            <field name="category_id" ref="module_category_ibs_cotizador"/>
            <field name="sequence">20</field>
        </record>
        <record id="group_costos" model="res.groups">
            <field name="name">Ver costos</field>
            <field name="privilege_id" ref="privilege_costos"/>
            <field name="comment">Habilita la pestaña de Items, costos fijos y variables.</field>
        </record>

        <record id="privilege_diseno" model="res.groups.privilege">
            <field name="name">Diseño</field>
            <field name="category_id" ref="module_category_ibs_cotizador"/>
            <field name="sequence">30</field>
        </record>
        <record id="group_diseno" model="res.groups">
            <field name="name">Ver diseños</field>
            <field name="privilege_id" ref="privilege_diseno"/>
            <field name="comment">Habilita la pestaña de administración de diseños.</field>
        </record>

        <record id="privilege_materiales" model="res.groups.privilege">
            <field name="name">Materiales y operaciones</field>
            <field name="category_id" ref="module_category_ibs_cotizador"/>
            <field name="sequence">40</field>
        </record>
        <record id="group_materiales" model="res.groups">
            <field name="name">Ver materiales y operaciones</field>
            <field name="privilege_id" ref="privilege_materiales"/>
            <field name="comment">Habilita la pestaña de BOM y rutas de producción.</field>
        </record>

        <record id="privilege_acceso_total" model="res.groups.privilege">
            <field name="name">Acceso Total</field>
            <field name="category_id" ref="module_category_ibs_cotizador"/>
            <field name="sequence">5</field>
        </record>

        <record id="group_acceso_total" model="res.groups">
            <field name="name">Administrador</field>
            <field name="privilege_id" ref="privilege_acceso_total"/>
            <field name="comment">Habilita absolutamente todas las pestañas del cotizador automáticamente.</field>
            <field name="implied_ids" eval="[
                (4, ref('group_cotizar_producto')), 
                (4, ref('group_costos')), 
                (4, ref('group_diseno')), 
                (4, ref('group_materiales'))
            ]"/>
        </record>

    </data>
</odoo>