<odoo>
    <data>
        <record id='view_range_template_list' model='ir.ui.view'>
            <field name='name'>ibs.range_template_list</field>
            <field name='model'>ibs.range_template</field>
            <field name='arch' type='xml'>
                <list>
                    <field name='name'/>
                    <field name='minimum_range'/>
                    <field name='maximum_range'/>
                    <field name='quantity'/>
                    <field name='percentage'/>
                    <field name='discount_points'/>
                </list>
            </field>
        </record>


        <record id='view_range_template_form' model='ir.ui.view'>
            <field name='name'>ibs.range_template_form</field>
            <field name='model'>ibs.range_template</field>
            <field name='arch' type='xml'>
                <form>
                    <sheet>
                        <div class='oe_title'>
                            <h1>
                                <field name='name' placeholder='Nombre'/>
                            </h1>
                        </div>
                        <group>
                            <field name='minimum_range'/>
                            <field name='maximum_range'/>
                            <field name='quantity'/>
                             <field name='percentage'/>
                             <field name='discount_points'/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>

        </record>

        <record id='action_range_template' model='ir.actions.act_window'>
            <field name='name'>Plantillas de Rango</field>
            <field name='res_model'>ibs.range_template</field>
            <field name='view_mode'>list,form</field>
        </record>
    </data>
</odoo>