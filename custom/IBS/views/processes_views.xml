<odoo>
    <data>
        <record id="view_processes_list" model="ir.ui.view">
            <field name="name">ibs.processes.list</field>
            <field name="model">ibs.processes</field>
            <field name="arch" type="xml">
                <list string="Procesos">
                    <field name="name"/>
                    <field name="project"/>
                </list>
            </field>
        </record>


        <record id="view_processes_form" model="ir.ui.view">
            <field name="name">ibs.processes.form</field>
            <field name="model">ibs.processes</field>
            <field name="arch" type="xml">
                <form string="Proceso">
                    <sheet>
                        <div class='oe_title'>
                            <h1>
                                <field name='name' placeholder='Nombre'/>
                            </h1>
                        </div>
                        <group>
                            <field name="project"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_processes" model="ir.actions.act_window">
            <field name="name">Procesos</field>
            <field name="res_model">ibs.processes</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>