<odoo>
    <data>
        <record id="view_cost_type_list" model="ir.ui.view">
            <field name="name">cost_type.list</field>
            <field name="model">ibs.cost_type</field>
            <field name="arch" type="xml">
                <list string="Tipo de costo">
                    <field name="name"/>
                    <field name="code"/>
                </list>
            </field>
        </record>
        <record id="view_cost_type_form" model="ir.ui.view">
            <field name="name">cost_type.form</field>
            <field name="model">ibs.cost_type</field>
            <field name="arch" type="xml">
                <form string="Tipo de costo">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder='Nombre'/>
                            </h1>
                        </div>
                        <group>
                            <field name="code"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_cost_type" model="ir.actions.act_window">
            <field name="name">Tipo de costo</field>
            <field name="res_model">ibs.cost_type</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>