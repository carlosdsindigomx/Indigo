<odoo>
    <data>
        <record id="types_of_printing_list_view" model="ir.ui.view">
            <field name="name">types.of.printing.list.view</field>
            <field name="model">ibs.types_of_printing</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="types_of_printing_form_view" model="ir.ui.view">
            <field name="name">types.of.printing.form.view</field>
            <field name="model">ibs.types_of_printing</field>
            <field name="arch" type="xml">
                <form string="Tipo de impresión">
                    <sheet>
                        <div class='oe_title'>
                            <h1>
                                <field name='name' placeholder='Tipo de Producto'/>
                            </h1>
                        </div>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_types_of_printing" model="ir.actions.act_window">
            <field name="name">Tipos de impresión</field>
            <field name="res_model">ibs.types_of_printing</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>