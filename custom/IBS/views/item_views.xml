<odoo>
    <data>
        <record id='view_item_list' model='ir.ui.view'>
            <field name='name'>ibs.item_ibs.list</field>
            <field name='model'>ibs.item_ibs</field>
            <field name='arch' type='xml'>
                <list>
                    <field name='name'/>
                    <field name='item_type_id'/>
                    <field name="cost_type" />
                </list>
            </field>
        </record>

        <record id='view_item_form' model='ir.ui.view'>
            <field name='name'>ibs.item_ibs.form</field>
            <field name='model'>ibs.item_ibs</field>
            <field name='arch' type='xml'>
                <form>
                    <sheet>
                        <div class='oe_title'>
                            <h1>
                                <field name='name' placeholder='Ítem'/>
                            </h1>
                        </div>
                        <group>

                            <group>
                                <field name='item_type_id'/>
                                <field name="cost_type" />
                            </group>
                            <group>

                            </group>
                        </group>

                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id='action_item_ibs' model='ir.actions.act_window'>
            <field name='name'>Item</field>
            <field name='res_model'>ibs.item_ibs</field>
            <field name='view_mode'>list,form</field>
        </record>
    </data>
</odoo>