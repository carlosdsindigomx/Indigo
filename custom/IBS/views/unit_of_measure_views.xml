<odoo>
    <data>
        <record id='unit_of_measure_list_view' model='ir.ui.view'>
            <field name='name'>unit.of.measure.list.view</field>
            <field name='model'>ibs.unit_of_measure</field>
            <field name='arch' type='xml'>
                <list>
                    <field name='name'/>
                </list>
            </field>
        </record>

        <record id='unit_of_measure_form_view' model='ir.ui.view'>
            <field name='name'>unit.of.measure.form.view</field>
            <field name='model'>ibs.unit_of_measure</field>
            <field name='arch' type='xml'>
                <form string='Unidad de Medida'>
                    <sheet>
                        <div class='oe_title'>
                            <h1>
                                <field name='name' placeholder='Unidad de Medida'/>
                            </h1>
                        </div>
                        <group>
                            <field name="product_type_ids" widget="many2many_checkboxes" nolabel="1"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id='action_unit_of_measure' model='ir.actions.act_window'>
            <field name='name'>Unidades de Medida</field>
            <field name='res_model'>ibs.unit_of_measure</field>
            <field name='view_mode'>list,form</field>
        </record>
    </data>
</odoo>