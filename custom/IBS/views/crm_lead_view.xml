<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_lead_view_form_inherit_ibs" model="ir.ui.view">
        <field name="name">crm.lead.view.form.inherit.ibs</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            
            <div name="button_box" position="inside">
                <button class="oe_stat_button" 
                        type="object" 
                        name="action_view_ibs_products" 
                        icon="fa-calculator">
                    <field name="ibs_product_count" widget="statinfo" string="Cotizador IBS"/>
                </button>
            </div>
            
        </field>
    </record>
</odoo>