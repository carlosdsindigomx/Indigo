<odoo>
    <data>
        <record id='view_byproduct_item_list' model='ir.ui.view'>
            <field name='name'>ibs.byproduct_item.list</field>
            <field name='model'>ibs.byproduct_item</field>
            <field name='arch' type='xml'>
                <list>
                    <field name='name'/>
                    <field name='type_by_product_item'/>
                    <field name="cost_type_id"/>
                    <field name="modify_quote"/>
                    <field name="cost_frame" readonly="not modify_quote"/>
                    <field name="price_frame" readonly="not modify_quote"/>
                </list>
            </field>
        </record>

        <record id='view_byproduct_item_form' model='ir.ui.view'>
            <field name='name'>ibs.byproduct_item.form</field>
            <field name='model'>ibs.byproduct_item</field>
            <field name='arch' type='xml'>
                <form>
                    <sheet>
                        <div class='oe_title'>
                            <h1>
                                <field name='name'/>
                            </h1>
                        </div>
                        <group>
                            <field name='type_by_product_item'/>
                            <field name="cost_type_id"/>
                            <field name="modify_quote"/>
                            <field name="cost_frame" readonly="not modify_quote"/>
                            <field name="price_frame" readonly="not modify_quote"/>
                        </group>
                        <notebook>
                            <page string="Materiales">
                                <field name="materials_ids">
                                    <list editable="bottom">
                                        <field name="product_id"/>
                                        <field name="bom"/>
                                        <field name="quantity_frame"/>
                                        <field name="full"/>
                                        <field name="less_than_one"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id='action_byproduct_item' model='ir.actions.act_window'>
            <field name='name'>Acabados y otros</field>
            <field name='res_model'>ibs.byproduct_item</field>
            <field name='view_mode'>list,form</field>
        </record>
    </data>
</odoo>