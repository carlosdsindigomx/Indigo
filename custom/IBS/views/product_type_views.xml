<odoo>
    <data>
        <record id='view_type_product_list' model='ir.ui.view'>
            <field name='name'>ibs.type_product.list</field>
            <field name='model'>ibs.product_type</field>
            <field name='arch' type='xml'>
                <list>
                    <field name='name'/>
                </list>
            </field>
        </record>

        <record id='view_type_product_form' model='ir.ui.view'>
            <field name='name'>ibs.type_product.form</field>
            <field name='model'>ibs.product_type</field>
            <field name='arch' type='xml'>
                <form>
                    <sheet>
                        <div class='oe_title'>
                            <h1>
                                <field name='name' placeholder='Tipo de Producto'/>
                            </h1>
                        </div>
                        <group>
                            <field name='printer_ids' widget="many2many_checkboxes"/>
                            <field name='unit_of_measure_ids' widget="many2many_checkboxes"/>
                            <field name='technica_data'/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id='action_type_product' model='ir.actions.act_window'>
            <field name='name'>Tipo de Producto</field>
            <field name='res_model'>ibs.product_type</field>
            <field name='view_mode'>list,form</field>
        </record>


    </data>
</odoo>