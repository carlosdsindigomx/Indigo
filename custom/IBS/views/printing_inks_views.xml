<odoo>
    <data>
        <record id="printing_inks_list_view" model="ir.ui.view">
            <field name="name">printing.inks.list.view</field>
            <field name="model">ibs.printing_inks</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="number_inks"/>
                    <field name='cost_frame'/>
                </list>
            </field>
        </record>

        <record id="printing_inks_form_view" model="ir.ui.view">
            <field name="name">printing.inks.form.view</field>
            <field name="model">ibs.printing_inks</field>
            <field name="arch" type="xml">
                <form string="Tinta de impresión">
                    <sheet>
                        <div class='oe_title'>
                            <h1>
                                <field name='name' placeholder='Tinta'/>
                            </h1>
                        </div>
                        <group>
                            <field name="number_inks"/>
                            <field name='cost_frame'/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_printing_inks" model="ir.actions.act_window">
            <field name="name">Tintas de impresión</field>
            <field name="res_model">ibs.printing_inks</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>