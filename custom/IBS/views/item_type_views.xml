<odoo>
    <data>
        <record id='view_item_type_list' model='ir.ui.view'>
            <field name='name'>ibs.item_type.list</field>
            <field name='model'>ibs.item_type</field>
            <field name='arch' type='xml'>
                <list>
                    <field name='name'/>
                    <field name='cost_type_id'/>
                </list>
            </field>
        </record>

        <record id='view_item_type_form' model='ir.ui.view'>
            <field name='name'>ibs.item_type.form</field>
            <field name='model'>ibs.item_type</field>
            <field name='arch' type='xml'>
                <form>
                    <sheet>
                        <div class='oe_title'>
                            <h1>
                                <field name='name' placeholder='Tipo de Ítem'/>

                            </h1>
                        </div>
                        <group>
                            <field name='cost_type_id'/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id='action_item_type' model='ir.actions.act_window'>
            <field name='name'>Tipo de Ítem</field>
            <field name='res_model'>ibs.item_type</field>
            <field name='view_mode'>list,form</field>
        </record>
    </data>
</odoo>