<odoo>
    <data>
        <record id='view_material_by_product_list' model='ir.ui.view'>
            <field name='name'>ibs.material_by_product.list</field>
            <field name='model'>ibs.material_by_product</field>
            <field name='arch' type='xml'>
                <list>
                    <field name='name'/>
                    <field name='product_id'/>
                    <field name='raw_material_id'/>
                    <field name="bom"/>
                    <field name='component_name'/>
                    <field name='quantity_frame'/>
                </list>
            </field>

        </record>

        <record id='view_material_by_product_form' model='ir.ui.view'>
            <field name='name'>ibs.material_by_product.form</field>
            <field name='model'>ibs.material_by_product</field>
            <field name='arch' type='xml'>
                <form>
                    <sheet>
                        <div>
                            <div class='oe_title'>
                                <h1>
                                    <field name='name' placeholder='Material por Producto'/>
                                </h1>
                            </div>
                        </div>
                        <group>
                            <group>
                                <!-- <field name="product_id"/> -->
                                <field name='raw_material_id'/>
                                <field name="bom"/>
                                <field name='component_name'/>
                                <field name='quantity_frame'/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id='action_material_by_product' model='ir.actions.act_window'>
            <field name='name'>Materiales por Producto</field>
            <field name='res_model'>ibs.material_by_product</field>
            <field name='view_mode'>list,form</field>

        </record>
    </data>
</odoo>