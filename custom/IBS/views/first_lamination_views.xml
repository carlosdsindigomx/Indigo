<odoo>
    <data>
        <record id='view_first_lamination_list' model='ir.ui.view'>
            <field name='name'>ibs.first_lamination.list</field>
            <field name='model'>ibs.first_lamination</field>
            <field name='arch' type='xml'>
                <list>
                    <field name='name'/>
                    <field name='cost_frame'/>
                </list>
            </field>
        </record>

        <record id='view_first_lamination_form' model='ir.ui.view'>
            <field name='name'>ibs.first_lamination.form</field>
            <field name='model'>ibs.first_lamination</field>
            <field name='arch' type='xml'>
                <form>
                    <sheet>
                        <div class='oe_title'>
                            <h1>
                                <field name='name' placeholder='Primera Laminación'/>
                            </h1>
                        </div>
                        <group>
                            <field name='cost_frame'/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>


        <record id='action_first_lamination' model='ir.actions.act_window'>
            <field name='name'>Primera Laminación</field>
            <field name='res_model'>ibs.first_lamination</field>
            <field name='view_mode'>list,form</field>
        </record>
    </data>
</odoo>
