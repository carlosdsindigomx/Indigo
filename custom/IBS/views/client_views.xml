<odoo>
    <data>
        <record id='view_client_list' model='ir.ui.view'>
            <field name='name'>ibs.client.list</field>
            <field name='model'>ibs.client</field>
            <field name='arch' type='xml'>
                <list>
                    <field name='name'/>
                    <field name='email'/>
                    <field name='phone'/>
                    <field name='address'/>
                </list>
            </field>
        </record>

        <record id='view_client_form' model='ir.ui.view'>
            <field name='name'>ibs.client.form</field>
            <field name='model'>ibs.client</field>
            <field name='arch' type='xml'>
                <form>
                    <sheet>
                        <div class='oe_title'>
                            <h1>
                                <field name='name' placeholder='Nombre del Cliente'/>
                            </h1>
                        </div>
                        <group>
                            <field name='partner_id'/>
                            <field name='email'/>
                            <field name='phone'/>
                            <field name='address'/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id='action_client' model='ir.actions.act_window'>
            <field name='name'>Clientes</field>
            <field name='res_model'>ibs.client</field>
            <field name='view_mode'>list,form</field>
        </record>
    </data>
</odoo>