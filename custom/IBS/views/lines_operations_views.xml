<odoo>
    <record id="view_ibs_lines_operations_list" model="ir.ui.view">
        <field name="name">ibs.lines.operations.list</field>
        <field name="model">ibs.lines.operations</field>
        <field name="arch" type="xml">
            <list string="Lines Operations">
                <field name="name"/>
                <field name="work_center_id"/>
                <field name="bom"/>
                <field name="frames"/>
                <field name="minutes"/>
            </list>
        </field>
    </record>

    <record id="view_ibs_lines_operations_form" model="ir.ui.view">
        <field name="name">ibs.lines.operations.form</field>
        <field name="model">ibs.lines.operations</field>
        <field name="arch" type="xml">
            <form string="Lines Operations">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="work_center_id"/>
                        <field name="bom"/>
                    </group>
                    <group>
                        <field name="frames"/>
                        <field name="minutes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ibs_lines_operations" model="ir.actions.act_window">
        <field name="name">Lines Operations</field>
        <field name="res_model">ibs.lines.operations</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>