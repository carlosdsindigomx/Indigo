<odoo>
    <data>
        <template id="template_tabla_costos_acabados">
            <table class="table table-sm table-bordered">
                <thead class="thead-light">
                    <tr>
                        <th style="width: 25%;">Tipo de Costo</th>
                        <th style="width: 25%; text-align: left;">Precio x Frame</th>
                        <th style="width: 25%; text-align: left;">Precio x Pieza</th>
                        <th style="width: 25%; text-align: left;">Precio Total</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-if="frame['price'] > 0">
                        <td>Por frame</td>
                        <td class="text-right">
                            <span t-esc="frame['px_frame']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                        </td>
                        <td class="text-right">
                            <span t-esc="frame['px_piece']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                        </td>
                        <td class="text-right">
                            <span t-esc="frame['price']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                        </td>
                    </tr>

                    <tr t-if="prorated['price'] > 0">
                        <td>Fijo Prorrateado</td>
                        <td class="text-right">
                            <span t-esc="prorated['px_frame']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                        </td>
                        <td class="text-right">
                            <span t-esc="prorated['px_piece']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                        </td>
                        <td class="text-right">
                            <span t-esc="prorated['price']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                        </td>
                    </tr>

                    <tr t-if="external['price'] > 0">
                        <td>Fijo Externo</td>
                        <td class="text-right">
                            <span t-esc="external['px_frame']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                        </td>
                        <td class="text-right">
                            <span t-esc="external['px_piece']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                        </td>
                        <td class="text-right">
                            <span t-esc="external['price']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                        </td>
                    </tr>

                    <tr t-if="piece['price'] > 0">
                        <td>Por pieza</td>
                        <td class="text-right">
                            <span t-esc="piece['px_frame']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                        </td>
                        <td class="text-right">
                            <span t-esc="piece['px_piece']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                        </td>
                        <td class="text-right">
                            <span t-esc="piece['price']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                        </td>
                    </tr>
                </tbody>
                <tfoot style="border-top: 2px solid #dee2e6;">
                    <tr style="font-weight: bold; background-color: #f8f9fa;">
                        <td class="text-right">TOTALES:</td>
                        <td class="text-right">
                            <span t-esc="totals['px_frame']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                        </td>
                        <td class="text-right">
                            <span t-esc="totals['px_piece']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                        </td>
                        <td class="text-right">
                            <span t-esc="totals['price']" t-options='{"widget": "monetary", "display_currency": currency}'/>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </template>
    </data>
</odoo>