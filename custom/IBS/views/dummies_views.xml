<odoo>
    <data>
        <record id='view_dummies_list' model='ir.ui.view'>
            <field name='name'>ibs.dummies.list</field>
            <field name='model'>ibs.dummies</field>
            <field name='arch' type='xml'>
                <list>
                    <field name='name'/>
                    <field name='version'/>
                    <field name='project_id'/>
                    <field name='ibs_product_id'/>
                    <field name='state' widget='badge' decoration-info="state == 'draft'" decoration-warning="state == 'in_production'" decoration-success="state == 'done'"/>
                </list>
            </field>
        </record>

        <record id='view_dummies_form' model='ir.ui.view'>
            <field name='name'>ibs.dummies.form</field>
            <field name='model'>ibs.dummies</field>
            <field name='arch' type='xml'>
                <form>
                    <header>
                        <button name="action_generate_mrp" 
                                string="Mandar a Producción" 
                                type="object" 
                                class="oe_highlight" 
                                invisible="state != 'draft'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,in_production,done"/>
                    </header>
                    <sheet>
                        <div class='oe_title'>
                            <h1>
                                <field name='name' placeholder='Nombre'/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name='version'/>
                                <field name='project_id'/>
                            </group>
                            <group>
                                <field name='ibs_product_id'/>
                                <field name='odoo_product_id'/>
                                <field name='product_qty'/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Órdenes de Producción">
                                <field name="mrp_production_ids" readonly="1"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id='action_dummies' model='ir.actions.act_window'>
            <field name='name'>Dummies</field>
            <field name='res_model'>ibs.dummies</field>
            <field name='view_mode'>list,form</field>
        </record>
    </data>
</odoo>