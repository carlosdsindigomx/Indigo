<odoo>
    <data>
        <record id='view_type_byproduct_item_list' model='ir.ui.view'>
            <field name='name'>ibs.type_byproduct_item.list</field>
            <field name='model'>ibs.type_byproduct_item</field>
            <field name='arch' type='xml'>
                <list>
                    <field name='name'/>
                </list>
            </field>
        </record>

        <record id='view_type_byproduct_item_form' model='ir.ui.view'>
            <field name='name'>ibs.type_byproduct_item.form</field>
            <field name='model'>ibs.type_byproduct_item</field>
            <field name='arch' type='xml'>
                <form>
                    <sheet>
                        <div class='oe_title'>
                            <h1>
                                <field name='name'/>
                            </h1>
                        </div>
                        <group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id='action_type_byproduct_item' model='ir.actions.act_window'>
            <field name='name'>Tipo de item de subproducto</field>
            <field name='res_model'>ibs.type_byproduct_item</field>
            <field name='view_mode'>list,form</field>
        </record>
    </data>
</odoo>