<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sat_xml_import_wizard_form" model="ir.ui.view">
        <field name="name">sat.xml.import.wizard.form</field>
        <field name="model">sat.xml.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar XMLs del SAT">
                <sheet>
                    <p class="text-muted">
                        Selecciona los archivos XML
                    </p>
                    <group>
                        <field name="attachment_ids" widget="many2many_binary" string="Archivos" nolabel="1"/>
                    </group>
                    <footer>
                        <button name="action_importar_masivo" string="Importar" type="object" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>